# Copy this file to .env and fill in your own values.
# .env is git-ignored. Never commit real keys.

# Model provider (OpenAI)
OPENAI_API_KEY=replace_with_your_openai_key

# Allow Langflow to read provider keys from environment variables
LANGFLOW_VARIABLES_TO_GET_FROM_ENVIRONMENT=OPENAI_API_KEY
LANGFLOW_FALLBACK_TO_ENV_VAR=True

# Langflow API key used by external callers such as Camunda (x-api-key header).
# Create this in Langflow only after your flow works in the Playground.
LANGFLOW_API_KEY=replace_with_your_langflow_api_key

# Optional: local Ollama server base URL (default shown)
# OLLAMA_BASE_URL=http://localhost:11434
